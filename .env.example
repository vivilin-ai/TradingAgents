# Telegram Bot (optional — enables /analyze, /batch, /status + scheduled notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=   # comma-separated; defaults to TELEGRAM_CHAT_ID if empty

